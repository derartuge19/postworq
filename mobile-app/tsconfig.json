{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "jsx": "react-native",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noEmit": true,
    "typeRoots": [],
    "types": [],
    "lib": ["ES2020"],
    "target": "ES2020"
  },
  "include": ["src/**/*", "App.js", "*.js"],
  "exclude": ["node_modules", "babel.config.js", "metro.config.js"]
}
