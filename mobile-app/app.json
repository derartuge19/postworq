{
  "expo": {
    "name": "Flip Star",
    "slug": "selfistar",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.flipstar.app"
    },
    "android": {
      "package": "com.flipstar.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "./plugins/withSuppressKotlinVersionCompatibility.js",
      "expo-secure-store",
      "expo-av",
      "expo-asset",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25",
            "gradleVersion": "8.10.2"
          }
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "4ce08651-ca98-49af-99c8-10ed9f3fab94"
      }
    },
    "owner": "ed123456"
  }
}
