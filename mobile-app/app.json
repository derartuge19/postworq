{
  "expo": {
    "name": "SelfiStar",
    "slug": "selfistar",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.selfistar.app"
    },
    "android": {
      "package": "com.selfistar.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-secure-store",
      "expo-av",
      "expo-asset",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25",
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "buildToolsVersion": "34.0.0",
            "composeCompilerVersion": "1.5.14"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "6b16eda1-c255-4150-bdbc-8070069416bb"
      }
    }
  }
}
