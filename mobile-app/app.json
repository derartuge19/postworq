{
  "expo": {
    "name": "Flip Star",
    "slug": "selfistar",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.flipstar.app"
    },
    "android": {
      "package": "com.flipstar.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "./plugins/withSuppressKotlinVersionCompatibility.js",
      "expo-secure-store",
      "expo-av",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "6b16eda1-c255-4150-bdbc-8070069416bb"
      }
    }
  }
}
