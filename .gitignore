# Ignore zip files
*.zip

# Ignore node modules
node_modules/
**/node_modules/

# Ignore build files
dist/
build/
**/dist/
**/build/

# Ignore environment files
.env
.env.local
.env.production
**/.env
**/.env.local
**/.env.production

# Ignore IDE files
.vscode/
.idea/
**/.vscode/
**/.idea/

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore lock files (optional)
package-lock.json
**/package-lock.json

# Ignore log files
*.log
**/*.log

# Ignore database files
*.db
*.sqlite
**/*.db
**/*.sqlite

# Ignore Python cache
__pycache__/
**/__pycache__/
*.pyc
**/*.pyc

# Ignore Django media/uploads
media/
uploads/
**/media/
**/uploads/

# Ignore Gradle cache
.gradle/
**/.gradle/
